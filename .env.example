APP_ENV=local
LOG_LEVEL=INFO
CLINIC_TIMEZONE=Asia/Kolkata
DATABASE_URL=postgresql+asyncpg://voice_agent:voice_agent@localhost:5432/voice_agent
PMS_PROVIDER=mock
CLINIKO_API_KEY= # gitleaks:allow - intentionally empty example value
CLINIKO_SHARD=au1
CLINIKO_USER_AGENT=2care-clinic-voice-agent/0.1 contact@example.com
CLINIKO_PATIENT_IDS_BY_PHONE_JSON={"+919999999999":"cliniko-patient-id"}
VOICE_PLATFORM=unselected
RETELL_API_KEY= # gitleaks:allow - intentionally empty example value
RETELL_AGENT_ID=
RETELL_TOOL_TOKEN=replace-with-at-least-32-random-characters
REQUEST_HMAC_SECRET=replace-with-at-least-32-random-characters
AVAILABILITY_TOKEN_SECRET=replace-with-a-different-32-character-secret
# Optional exact browser origins. Keep empty for the server-to-server voice API.
CORS_ALLOWED_ORIGINS=
SAME_DAY_BOOKING_BUFFER_MINUTES=60
AWS_REGION=ap-south-1
