{
  "schema_version": 1,
  "authentication": {
    "scheme": "hmac-sha256",
    "headers": ["X-2Care-Timestamp", "X-2Care-Event-Id", "X-2Care-Signature"]
  },
  "tools": [
    {
      "name": "bootstrap_call",
      "method": "POST",
      "path": "/v1/tools/bootstrap-call",
      "purpose": "Start or replay a call session and recover callback/drop context",
      "required": ["platform_call_id", "direction", "caller_phone", "called_phone"]
    },
    {
      "name": "search_availability",
      "method": "POST",
      "path": "/v1/tools/search-availability",
      "purpose": "Get fresh conflict-free slots and opaque booking tokens",
      "required": ["call_id", "business_id", "practitioner_ids", "appointment_type_id", "starts_at", "ends_at"]
    },
    {
      "name": "book_appointment",
      "method": "POST",
      "path": "/v1/tools/book-appointment",
      "purpose": "Book one offered slot with an unambiguous patient",
      "required": ["call_id", "patient_id", "full_name", "availability_token", "idempotency_key"]
    },
    {
      "name": "list_patient_appointments",
      "method": "POST",
      "path": "/v1/tools/list-patient-appointments",
      "purpose": "List appointments for the selected patient only",
      "required": ["call_id", "patient_id"]
    },
    {
      "name": "reschedule_appointment",
      "method": "POST",
      "path": "/v1/tools/reschedule-appointment",
      "purpose": "Move one selected appointment idempotently",
      "required": ["call_id", "appointment_id", "starts_at", "ends_at", "idempotency_key"]
    },
    {
      "name": "cancel_appointment",
      "method": "POST",
      "path": "/v1/tools/cancel-appointment",
      "purpose": "Cancel one selected appointment idempotently",
      "required": ["call_id", "appointment_id", "idempotency_key"]
    },
    {
      "name": "save_call_checkpoint",
      "method": "POST",
      "path": "/v1/tools/save-call-checkpoint",
      "purpose": "Persist authoritative workflow facts but never stale slot tokens",
      "required": ["session_id", "checkpoint"]
    },
    {
      "name": "log_follow_up",
      "method": "POST",
      "path": "/v1/tools/log-follow-up",
      "purpose": "Create an honest human callback work item",
      "required": ["session_id", "idempotency_key", "reason", "details"]
    }
  ]
}
